{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "./out",
    "rootDir": "./src"
  },
  "include": ["src/main/**/*", "src/preload/**/*", "src/shared/**/*", "src/mcp/**/*"]
}
